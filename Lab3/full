const size_t N = 5;

// ---------- Печать массивов ----------

void printMs(const unsigned short a[], size_t n) {
    for (size_t j = 0; j < n; ++j) {
        std::printf("%04hX", static_cast<unsigned int>(a[j]));
        if (j + 1 < n) {
            std::printf(" ");
        }
    }
    std::printf("\n");
}

void printMl(const unsigned int a[], size_t n) {
    for (size_t j = 0; j < n; ++j) {
        std::printf("%08X", a[j]);
        if (j + 1 < n) {
            std::printf(" ");
        }
    }
    std::printf("\n");
}

void printMq(const unsigned long long a[], size_t n) {
    for (size_t j = 0; j < n; ++j) {
        std::printf("%016llX", a[j]);
        if (j + 1 < n) {
            std::printf(" ");
        }
    }
    std::printf("\n");
}

void printMfsHex(const float a[], size_t n) {
    for (size_t j = 0; j < n; ++j) {
        unsigned int bits = 0;
        std::memcpy(&bits, &a[j], sizeof(bits));
        std::printf("%08X", bits);
        if (j + 1 < n) {
            std::printf(" ");
        }
    }
    std::printf("\n");
}

void printMflHex(const double a[], size_t n) {
    for (size_t j = 0; j < n; ++j) {
        unsigned long long bits = 0;
        std::memcpy(&bits, &a[j], sizeof(bits));
        std::printf("%016llX", bits);
        if (j + 1 < n) {
            std::printf(" ");
        }
    }
    std::printf("\n");
}

// ---------- Проверка SIMD ----------

void cpuid_leaf1(unsigned int &eax, unsigned int &ebx,
                 unsigned int &ecx, unsigned int &edx) {
    eax = 1;
    asm volatile(
        "cpuid"
        : "+a"(eax), "=b"(ebx), "=c"(ecx), "=d"(edx)
        :
        :
    );
}

unsigned long long xgetbv0() {
    unsigned int eax = 0;
    unsigned int edx = 0;
    asm volatile(
        "xgetbv"
        : "=a"(eax), "=d"(edx)
        : "c"(0)
        :
    );
    return (static_cast<unsigned long long>(edx) << 32) | eax;
}

bool hasSSE() {
    unsigned int eax = 0, ebx = 0, ecx = 0, edx = 0;
    cpuid_leaf1(eax, ebx, ecx, edx);
    return (edx & (1u << 25)) != 0;
}

bool hasAVX() {
    unsigned int eax = 0, ebx = 0, ecx = 0, edx = 0;
    cpuid_leaf1(eax, ebx, ecx, edx);

    bool avxBit = (ecx & (1u << 28)) != 0;
    if (!avxBit) {
        return false;
    }

    bool osxsaveBit = (ecx & (1u << 27)) != 0;
    if (!osxsaveBit) {
        return false;
    }

    unsigned long long xcr0 = xgetbv0();
    return (xcr0 & 0x6) == 0x6;
}

// ---------- Ввод индекса ----------

bool readIndex(size_t &i, size_t left, size_t right) {
    std::cout << "Введите i из диапазона [" << left << ".." << right << "]: ";
    if (!(std::cin >> i) || i < left || i > right) {
        std::cout << "Ошибка ввода.\n";
        return false;
    }
    return true;
}

// ---------- Задание 1 ----------

void task1() {
    unsigned short Ms[N] = {
        0xC0DE, 0xC0DE, 0xC0DE, 0xC0DE, 0xC0DE
    };

    unsigned int Ml[N] = {
        0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU
    };

    unsigned long long Mq[N] = {
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL
    };

    size_t i;
    if (!readIndex(i, 0, N - 2)) {
        return;
    }

    std::printf("\nMs до изменения:\n");
    printMs(Ms, N);
    asm volatile(
        "movw $18, %0"
        : "=m"(Ms[i])
    );
    std::printf("Ms после изменения:\n");
    printMs(Ms, N);

    std::printf("\nMl до изменения:\n");
    printMl(Ml, N);
    asm volatile(
        "movl $18, %0"
        : "=m"(Ml[i])
    );
    std::printf("Ml после изменения:\n");
    printMl(Ml, N);

    std::printf("\nMq до изменения:\n");
    printMq(Mq, N);
    asm volatile(
        "movq $18, %0"
        : "=m"(Mq[i])
    );
    std::printf("Mq после изменения:\n");
    printMq(Mq, N);
}


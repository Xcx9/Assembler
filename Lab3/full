// ---------- Задание 6 ----------
// Вариант 8 -> 16 бит

void task6() {
    short x = 1000;
    short y = 1500;
    short z = 0;
    short w = 0;

    std::printf("\nДо вставки:\n");
    std::printf("x = %hd, y = %hd, z = %hd, w = %hd\n", x, y, z, w);

    asm volatile(
        "movw %[x], %%ax\n\t"
        "addw %[y], %%ax\n\t"
        "movw %%ax, %[z]\n\t"
        "movw %[x], %%ax\n\t"
        "subw %[y], %%ax\n\t"
        "movw %%ax, %[w]\n\t"
        : [z] "=m"(z), [w] "=m"(w)
        : [x] "m"(x), [y] "m"(y)
        : "ax", "cc"
    );

    std::printf("После вставки:\n");
    std::printf("x = %hd, y = %hd, z = %hd, w = %hd\n", x, y, z, w);
}

// ---------- Задание 7 ----------
// Вариант 8 -> Mfs, x = -3/7, xmm1

void task7() {
    double Mfl[N] = {
        -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0
    };

    float Mfs[N] = {
        -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f
    };

    float x = -3.0f / 7.0f;

    bool sse = hasSSE();
    bool avx = hasAVX();

    size_t i;
    if (!readIndex(i, 0, N - 1)) {
        return;
    }

    std::printf("\nДоступность расширений:\n");
    std::printf("SSE: %s\n", sse ? "да" : "нет");
    std::printf("AVX: %s\n", avx ? "да" : "нет");

    if (!sse && !avx) {
        std::printf("Ошибка: на платформе нет ни SSE, ни AVX.\n");
        return;
    }

    std::printf("\nИсходные данные:\n");
    std::printf("x = %f\n", x);
    std::printf("Mfs до изменения:\n");
    printMfsHex(Mfs, N);

    (void)Mfl;

    if (avx) {
        std::printf("Используется AVX: vmovss, регистр xmm1.\n");

        asm volatile(
            "vmovss %[src], %%xmm1\n\t"
            "vmovss %%xmm1, (%[base], %[index], 4)"
            :
            : [src] "m"(x),
              [base] "r"(Mfs),
              [index] "r"(i)
            : "xmm1", "memory"
        );
    } else {
        std::printf("Используется SSE: movss, регистр xmm1.\n");

        asm volatile(
            "movss %[src], %%xmm1\n\t"
            "movss %%xmm1, (%[base], %[index], 4)"
            :
            : [src] "m"(x),
              [base] "r"(Mfs),
              [index] "r"(i)
            : "xmm1", "memory"
        );
    }

    std::printf("Mfs после изменения:\n");
    printMfsHex(Mfs, N);
}


// ------------------------------------------------------------
// ЗАДАНИЕ 2
// Вариант 8 -> массив Ml
// Нужно записать -1 в M[i], адрес массива и индекс передаются в РОН
// ------------------------------------------------------------
void task2() {                                                   // Функция для Л3 №2
    unsigned int Ml[N] = {                                       // Создаём массив Ml
        0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU
    };

    size_t i;                                                    // Индекс обязательно size_t по условию
    if (!readIndex(i, 0, N - 1)) {                               // Читаем индекс
        return;                                                  // Если ошибка, выходим
    }

    std::printf("\nMl до изменения:\n");                         // Печать до изменения
    printMl(Ml, N);                                              // Вывод массива

    asm volatile(                                                // Ассемблерная вставка
        "movl $-1, (%[base], %[index], 4)"                       // Записываем -1 по адресу base + index*4
        :                                                        // Нет выходных параметров C++
        : [base] "r"(Ml), [index] "r"(i)                         // Входные параметры в регистры: адрес массива и индекс
        : "memory"                                               // Сообщаем компилятору, что память изменилась
    );

    std::printf("Ml после изменения:\n");                        // Печать после изменения
    printMl(Ml, N);                                              // Вывод массива
}


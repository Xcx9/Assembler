// ------------------------------------------------------------
// ЗАДАНИЕ 6
// Вариант 8 -> 16 бит
// Нужно вычислить z = x + y и w = x - y
// ------------------------------------------------------------
void task6() {                                                   // Функция для Л3 №6
    short x = 1000;                                              // Первое 16-битное число
    short y = 1500;                                              // Второе 16-битное число
    short z = 0;                                                 // Здесь будет сумма
    short w = 0;                                                 // Здесь будет разность

    std::printf("\nДо вставки:\n");                              // Печать исходных данных
    std::printf("x = %hd, y = %hd, z = %hd, w = %hd\n",         // Вывод всех четырёх переменных
                x, y, z, w);

    asm volatile(                                                // Ассемблерная вставка
        "movw %[x], %%ax\n\t"                                    // Загружаем x в ax
        "addw %[y], %%ax\n\t"                                    // Прибавляем y к ax
        "movw %%ax, %[z]\n\t"                                    // Сохраняем сумму в z
        "movw %[x], %%ax\n\t"                                    // Снова загружаем x в ax
        "subw %[y], %%ax\n\t"                                    // Вычитаем y из ax
        "movw %%ax, %[w]\n\t"                                    // Сохраняем разность в w
        : [z] "=m"(z), [w] "=m"(w)                               // Выходные параметры: z и w
        : [x] "m"(x), [y] "m"(y)                                 // Входные параметры: x и y
        : "ax", "cc"                                             // ax портится, флаги процессора тоже меняются
    );

    std::printf("После вставки:\n");                             // Заголовок
    std::printf("x = %hd, y = %hd, z = %hd, w = %hd\n",         // Печатаем результат
                x, y, z, w);
}

// ------------------------------------------------------------
// ЗАДАНИЕ 7
// Вариант 8 -> массив Mfs
// x = -3/7
// Промежуточный регистр xmm1
// Если есть AVX -> использовать только AVX
// Иначе использовать SSE
// ------------------------------------------------------------
void task7() {                                                   // Функция для Л3 №7
    double Mfl[N] = {                                            // По условию создаём и Mfl
        -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0
    };

    float Mfs[N] = {                                             // И создаём Mfs
        -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f
    };

    float x = -3.0f / 7.0f;                                      // Значение x для варианта 8

    bool sse = hasSSE();                                         // Проверяем наличие SSE
    bool avx = hasAVX();                                         // Проверяем наличие AVX

    size_t i;                                                    // Индекс
    if (!readIndex(i, 0, N - 1)) {                               // Читаем индекс
        return;                                                  // При ошибке выходим
    }

    std::printf("\nДоступность расширений:\n");                  // Печатаем доступность расширений
    std::printf("SSE: %s\n", sse ? "да" : "нет");                // Вывод SSE
    std::printf("AVX: %s\n", avx ? "да" : "нет");                // Вывод AVX

    if (!sse && !avx) {                                          // Если нет ни SSE, ни AVX
        std::printf("Ошибка: на платформе нет ни SSE, ни AVX.\n");// Сообщаем об ошибке
        return;                                                  // Выходим
    }

    std::printf("\nИсходные данные:\n");                         // Заголовок
    std::printf("x = %f\n", x);                                  // Печатаем x
    std::printf("Mfs до изменения:\n");                          // Заголовок
    printMfsHex(Mfs, N);                                         // Печать массива как битовых шаблонов

    (void)Mfl;                                                   // Чтобы компилятор не ругался, что Mfl не используется

    if (avx) {                                                   // Если AVX доступен
        std::printf("Используется AVX: vmovss, регистр xmm1.\n");// Поясняем, что выбрано

        asm volatile(                                            // AVX-вставка
            "vmovss %[src], %%xmm1\n\t"                          // Загружаем x в xmm1
            "vmovss %%xmm1, (%[base], %[index], 4)"              // Записываем xmm1 в Mfs[i]
            :                                                    // Выходов нет
            : [src] "m"(x),                                      // x передаётся как память
              [base] "r"(Mfs),                                   // Адрес массива в РОН
              [index] "r"(i)                                     // Индекс в РОН
            : "xmm1", "memory"                                   // xmm1 и память изменяются
        );
    } else {                                                     // Иначе AVX нет, используем SSE
        std::printf("Используется SSE: movss, регистр xmm1.\n"); // Пояснение

        asm volatile(                                            // SSE-вставка
            "movss %[src], %%xmm1\n\t"                           // Загружаем x в xmm1
            "movss %%xmm1, (%[base], %[index], 4)"               // Записываем xmm1 в Mfs[i]
            :                                                    // Выходов нет
            : [src] "m"(x),                                      // x как память
              [base] "r"(Mfs),                                   // Адрес массива
              [index] "r"(i)                                     // Индекс
            : "xmm1", "memory"                                   // xmm1 и память изменяются
        );
    }

    std::printf("Mfs после изменения:\n");                       // Заголовок
    printMfsHex(Mfs, N);                                         // Печать массива после изменения
}

// ------------------------------------------------------------
// ЗАДАНИЕ 8
// Вариант 8 -> массив Mfs
// Нужно записать float-значение, равное целочисленному x
// Преобразование делать через cvtsi2ss / vcvtsi2ss
// ------------------------------------------------------------
void task8() {                                                   // Функция для Л3 №8
    double Mfl[N] = {                                            // Создаём Mfl по условию
        -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0, -3.0 / 7.0
    };

    float Mfs[N] = {                                             // Создаём Mfs по условию
        -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f, -3.0f / 7.0f
    };

    int x = -7;                                                  // Целочисленное x, которое преобразуем в float

    bool sse = hasSSE();                                         // Проверяем SSE
    bool avx = hasAVX();                                         // Проверяем AVX

    size_t i;                                                    // Индекс
    if (!readIndex(i, 0, N - 1)) {                               // Читаем индекс
        return;                                                  // При ошибке выходим
    }

    std::printf("\nДоступность расширений:\n");                  // Печатаем доступные расширения
    std::printf("SSE: %s\n", sse ? "да" : "нет");                // Вывод SSE
    std::printf("AVX: %s\n", avx ? "да" : "нет");                // Вывод AVX

    if (!sse && !avx) {                                          // Если нет ни SSE, ни AVX
        std::printf("Ошибка: на платформе нет ни SSE, ни AVX.\n");// Сообщаем об ошибке
        return;                                                  // Выходим
    }

    std::printf("\nИсходные данные:\n");                         // Заголовок
    std::printf("x = %d\n", x);                                  // Печатаем целочисленное x
    std::printf("Mfs до изменения:\n");                          // Заголовок
    printMfsHex(Mfs, N);                                         // Печать массива до изменения

    (void)Mfl;                                                   // Чтобы не было предупреждения о неиспользуемом Mfl

    if (avx) {                                                   // Если AVX есть
        std::printf("Используется AVX: vcvtsi2ssl + vmovss, регистр xmm1.\n");

        asm volatile(                                            // AVX-вставка
            "vcvtsi2ssl %[src], %%xmm1, %%xmm1\n\t"              // Преобразуем int x в float и кладём в xmm1
            "vmovss %%xmm1, (%[base], %[index], 4)"              // Записываем float из xmm1 в Mfs[i]
            :                                                    // Выходов нет
            : [src] "m"(x),                                      // x передаётся как память
              [base] "r"(Mfs),                                   // Адрес массива
              [index] "r"(i)                                     // Индекс
            : "xmm1", "memory"                                   // xmm1 и память изменяются
        );
    } else {                                                     // Если AVX нет
        std::printf("Используется SSE: cvtsi2ssl + movss, регистр xmm1.\n");

        asm volatile(                                            // SSE-вставка
            "cvtsi2ssl %[src], %%xmm1\n\t"                       // Преобразуем int x в float и кладём в xmm1
            "movss %%xmm1, (%[base], %[index], 4)"               // Записываем xmm1 в Mfs[i]
            :                                                    // Выходов нет
            : [src] "m"(x),                                      // x как память
              [base] "r"(Mfs),                                   // Адрес массива
              [index] "r"(i)                                     // Индекс
            : "xmm1", "memory"                                   // xmm1 и память изменяются
        );
    }

    std::printf("Mfs после изменения:\n");                       // Заголовок
    printMfsHex(Mfs, N);                                         // Печать массива после изменения
}


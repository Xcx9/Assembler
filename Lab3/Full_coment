        "movl $18, %0"                                           // Записать 18 в 32-битный элемент
        : "=m"(Ml[i])                                            // Выходной операнд: память Ml[i]
    );
    std::printf("Ml после изменения:\n");                        // Заголовок
    printMl(Ml, N);                                              // Печать массива после изменения


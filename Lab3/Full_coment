const size_t N = 5;    // По Л1 №3 длина массивов N = 5

// ------------------------------------------------------------
// Функция печати массива unsigned short в шестнадцатеричном виде
// ------------------------------------------------------------
void printMs(const unsigned short a[], size_t n) {               // Принимаем массив 16-битных чисел и его длину
    for (size_t j = 0; j < n; ++j) {                             // Проходим по всем элементам массива
        std::printf("%04hX", static_cast<unsigned int>(a[j]));   // Печатаем элемент как 4-значное HEX-число
        if (j + 1 < n) {                                         // Если это не последний элемент
            std::printf(" ");                                    // Печатаем пробел между элементами
        }
    }
    std::printf("\n");                                           // После массива перевод строки
}

// ------------------------------------------------------------
// Функция печати массива unsigned int в шестнадцатеричном виде
// ------------------------------------------------------------
void printMl(const unsigned int a[], size_t n) {                 // Принимаем массив 32-битных чисел и его длину
    for (size_t j = 0; j < n; ++j) {                             // Проходим по всем элементам массива
        std::printf("%08X", a[j]);                               // Печатаем элемент как 8-значное HEX-число
        if (j + 1 < n) {                                         // Если это не последний элемент
            std::printf(" ");                                    // Печатаем пробел между элементами
        }
    }
    std::printf("\n");                                           // После массива перевод строки
}

// ------------------------------------------------------------
// Функция печати массива unsigned long long в HEX
// ------------------------------------------------------------
void printMq(const unsigned long long a[], size_t n) {           // Принимаем массив 64-битных чисел и его длину
    for (size_t j = 0; j < n; ++j) {                             // Проходим по всем элементам массива
        std::printf("%016llX", a[j]);                            // Печатаем элемент как 16-значное HEX-число
        if (j + 1 < n) {                                         // Если это не последний элемент
            std::printf(" ");                                    // Печатаем пробел
        }
    }
    std::printf("\n");                                           // Перевод строки после массива
}

// ------------------------------------------------------------
// Печать массива float как набора битов в HEX
// ------------------------------------------------------------
void printMfsHex(const float a[], size_t n) {                    // Принимаем массив float и его длину
    for (size_t j = 0; j < n; ++j) {                             // Проходим по всем элементам
        unsigned int bits = 0;                                   // Переменная, куда скопируем 32 бита float
        std::memcpy(&bits, &a[j], sizeof(bits));                 // Копируем байты float в bits без преобразования значения
        std::printf("%08X", bits);                               // Печатаем биты float как 8-значное HEX-число
        if (j + 1 < n) {                                         // Если это не последний элемент
            std::printf(" ");                                    // Печатаем пробел
        }
    }
    std::printf("\n");                                           // Перевод строки
}


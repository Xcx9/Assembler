    asm volatile(                                                // Ассемблерная вставка
        "movw $18, %0"                                           // Записать непосредственное значение 18 в 16-битный элемент
        : "=m"(Ms[i])                                            // Выходной операнд: память Ms[i]
    );
    std::printf("Ms после изменения:\n");                        // Заголовок
    printMs(Ms, N);                                              // Печать массива после изменения

    std::printf("\nMl до изменения:\n");                         // Заголовок
    printMl(Ml, N);                                              // Печать массива до изменения

    unsigned short Ms[N] = {                                     // Массив 16-битных чисел
        0xC0DE, 0xC0DE, 0xC0DE, 0xC0DE, 0xC0DE
    };

    unsigned int Ml[N] = {                                       // Массив 32-битных чисел
        0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU
    };

    unsigned long long Mq[N] = {                                 // Массив 64-битных чисел
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL,
        0x000D15A550C1A7EDULL
    };

    size_t i;                                                    // Индекс элемента
    if (!readIndex(i, 0, N - 2)) {                               // По условию i должен быть в диапазоне [0, N-2]
        return;                                                  // Если ввод некорректный, выходим

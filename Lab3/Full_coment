// ------------------------------------------------------------
// Вызов CPUID с leaf = 1
// Эта функция нужна для проверки наличия SSE и AVX
// ------------------------------------------------------------
void cpuid_leaf1(unsigned int &eax, unsigned int &ebx,
                 unsigned int &ecx, unsigned int &edx) {         // Функция возвращает значения регистров после cpuid
    eax = 1;                                                     // Загружаем в eax значение 1: leaf 1 для cpuid
    asm volatile(                                                // Начинаем ассемблерную вставку
        "cpuid"                                                  // Выполняем инструкцию cpuid
        : "+a"(eax), "=b"(ebx), "=c"(ecx), "=d"(edx)             // Выходы: eax, ebx, ecx, edx
        :                                                        // Входов, кроме eax, нет
        :                                                        // Дополнительных clobbers нет
    );
}

// ------------------------------------------------------------
// Чтение регистра XCR0 через xgetbv
// Нужно, чтобы проверить, разрешила ли ОС использовать AVX
// ------------------------------------------------------------
unsigned long long xgetbv0() {                                   // Функция возвращает значение XCR0
    unsigned int eax = 0;                                        // Младшие 32 бита результата
    unsigned int edx = 0;                                        // Старшие 32 бита результата
    asm volatile(                                                // Ассемблерная вставка
        "xgetbv"                                                 // Команда xgetbv
        : "=a"(eax), "=d"(edx)                                   // Результат приходит в eax и edx
        : "c"(0)                                                 // В ecx передаём 0, это значит XCR0
        :                                                        // Дополнительных clobbers нет
    );
    return (static_cast<unsigned long long>(edx) << 32) | eax;  // Склеиваем edx:eax в одно 64-битное число
}

// ------------------------------------------------------------
// Проверка поддержки SSE
// ------------------------------------------------------------
bool hasSSE() {                                                  // Функция возвращает true, если SSE есть
    unsigned int eax = 0, ebx = 0, ecx = 0, edx = 0;            // Подготавливаем переменные под регистры
    cpuid_leaf1(eax, ebx, ecx, edx);                             // Вызываем cpuid leaf 1
    return (edx & (1u << 25)) != 0;                              // Проверяем бит 25 регистра edx: это признак SSE
}

// ------------------------------------------------------------
// Проверка поддержки AVX
// ------------------------------------------------------------
bool hasAVX() {                                                  // Функция возвращает true, если AVX реально можно использовать
    unsigned int eax = 0, ebx = 0, ecx = 0, edx = 0;            // Подготавливаем переменные
    cpuid_leaf1(eax, ebx, ecx, edx);                             // Получаем информацию о процессоре

    bool avxBit = (ecx & (1u << 28)) != 0;                       // Бит 28 ecx = наличие AVX в процессоре
    if (!avxBit) {                                               // Если процессор не поддерживает AVX
        return false;                                            // Сразу возвращаем false
    }

    bool osxsaveBit = (ecx & (1u << 27)) != 0;                   // Бит 27 ecx = ОС умеет сохранять расширенные регистры
    if (!osxsaveBit) {                                           // Если ОС этого не умеет
        return false;                                            // AVX использовать нельзя
    }

    unsigned long long xcr0 = xgetbv0();                         // Читаем XCR0
    return (xcr0 & 0x6) == 0x6;                                  // Проверяем, разрешены ли XMM и YMM состояния
}

// ------------------------------------------------------------
// Универсальный ввод индекса i
// ------------------------------------------------------------
bool readIndex(size_t &i, size_t left, size_t right) {           // Функция читает индекс i в заданном диапазоне
    std::cout << "Введите i из диапазона ["                      // Выводим приглашение
              << left << ".." << right << "]: ";
    if (!(std::cin >> i) || i < left || i > right) {            // Проверяем корректность ввода и диапазон
        std::cout << "Ошибка ввода.\n";                          // Сообщаем об ошибке
        return false;                                            // Возвращаем false
    }
    return true;                                                 // Иначе всё хорошо
}


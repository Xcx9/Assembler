// ------------------------------------------------------------
void task4() {                                                   // Функция для Л3 №4
    unsigned int Ml[N] = {                                       // Создаём массив Ml
        0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU, 0xDEADBEEFU
    };

    volatile unsigned int x = 0x12345678U;                       // Переменная x, volatile помогает не выбросить её из памяти

    size_t i;                                                    // Индекс
    if (!readIndex(i, 0, N - 1)) {                               // Читаем индекс
        return;                                                  // При ошибке выходим
    }

    std::printf("\nИсходные данные:\n");                         // Заголовок
    std::printf("x = %08X\n", x);                                // Печатаем x
    std::printf("Ml до изменения:\n");                           // Заголовок
    printMl(Ml, N);                                              // Печать массива

    asm volatile(                                                // Ассемблерная вставка
        "movl %[src], %%eax\n\t"                                 // Загружаем x из памяти в eax
        "movl %%eax, (%[base], %[index], 4)"                     // Записываем eax в Ml[i]
        :                                                        // Выходов нет
        : [src] "m"(x),                                          // x передаётся как память
          [base] "r"(Ml),                                        // Адрес массива в регистр
          [index] "r"(i)                                         // Индекс в регистр
        : "eax", "memory"                                        // eax портится, память меняется
    );

    std::printf("Ml после изменения:\n");                        // Заголовок
    printMl(Ml, N);                                              // Печать массива
}

